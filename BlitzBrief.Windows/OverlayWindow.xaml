<Window x:Class="BlitzBrief.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BlitzBrief"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="Manual">
  <Border CornerRadius="22"
          Padding="18,11"
          Background="#F0151B27"
          BorderBrush="#33FFFFFF"
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="5" Opacity="0.45" Color="Black" />
    </Border.Effect>

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
      <!-- Zuhören: Mikrofon-Punkt -->
      <Ellipse x:Name="MicDot"
               Width="11" Height="11"
               Margin="0,0,12,0"
               VerticalAlignment="Center"
               Fill="#FF4D4F" />

      <!-- Zuhören: Live-Pegel-Balken -->
      <StackPanel x:Name="LevelBars" Orientation="Horizontal" VerticalAlignment="Center" Height="26">
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
        <Rectangle Width="3" Height="6" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="#8AB4F8" VerticalAlignment="Center" />
      </StackPanel>

      <!-- Verarbeiten: Spinner -->
      <Grid x:Name="Spinner" Width="20" Height="20" Visibility="Collapsed" VerticalAlignment="Center">
        <Ellipse Width="20" Height="20" Stroke="#33FFFFFF" StrokeThickness="2.5" />
        <Path x:Name="SpinnerArc"
              Stroke="#8AB4F8"
              StrokeThickness="2.5"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Data="M 10,0.5 A 9.5,9.5 0 0 1 19.5,10"
              RenderTransformOrigin="0.5,0.5">
          <Path.RenderTransform>
            <RotateTransform x:Name="SpinnerRotate" Angle="0" />
          </Path.RenderTransform>
        </Path>
      </Grid>

      <TextBlock x:Name="StatusText"
                 Margin="13,0,0,0"
                 VerticalAlignment="Center"
                 FontFamily="Segoe UI"
                 FontSize="13"
                 FontWeight="SemiBold"
                 Foreground="#F4F7FB"
                 Text="Sprich jetzt" />
    </StackPanel>
  </Border>
</Window>
