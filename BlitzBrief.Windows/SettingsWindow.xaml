<Window x:Class="BlitzBrief.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BlitzBrief Einstellungen"
        Width="700"
        Height="760"
        MinWidth="600"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI"
        FontSize="13">
  <Window.Resources>
    <SolidColorBrush x:Key="TextMain" Color="#17202A" />
    <SolidColorBrush x:Key="TextMuted" Color="#5F6B7A" />
    <SolidColorBrush x:Key="PanelBorder" Color="#D8DEE8" />
    <SolidColorBrush x:Key="Primary" Color="#2563EB" />

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextMain}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PageTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="Description" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="RowLabel" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="Panel" TargetType="Border">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="BorderBrush" Value="#C9D2DF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="PasswordBox">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="BorderBrush" Value="#C9D2DF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="BorderBrush" Value="#C9D2DF" />
    </Style>

    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="BorderBrush" Value="#C9D2DF" />
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource Primary}" />
      <Setter Property="BorderBrush" Value="{StaticResource Primary}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </Window.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20" Orientation="Vertical">
      <TextBlock Text="BlitzBrief Einstellungen" Style="{StaticResource PageTitle}" />
      <TextBlock Text="Einstellungen werden automatisch gespeichert." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,14" />

      <!-- Zugang -->
      <Border Style="{StaticResource Panel}">
        <StackPanel>
          <TextBlock Text="Zugang" Style="{StaticResource SectionTitle}" />
          <TextBlock x:Name="ApiKeyStatusText" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,8" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="ApiKeyBox" Grid.Column="0" />
            <Button Grid.Column="1" Content="Aus Zwischenablage" Margin="8,0,0,0" Click="PasteApiKey_Click" />
            <Button Grid.Column="2" Content="Speichern" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" Click="SaveApiKey_Click" />
            <Button Grid.Column="3" Content="L&#x00F6;schen" Margin="8,0,0,0" Click="DeleteApiKey_Click" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Allgemein -->
      <Border Style="{StaticResource Panel}">
        <StackPanel>
          <TextBlock Text="Allgemein" Style="{StaticResource SectionTitle}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Sprache" Grid.Row="0" Grid.Column="0" Style="{StaticResource RowLabel}" />
            <ComboBox x:Name="LanguageBox" Grid.Row="0" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,0,0,8" SelectionChanged="ComboBox_Changed">
              <ComboBoxItem Content="Deutsch (de)" />
              <ComboBoxItem Content="Englisch (en)" />
              <ComboBoxItem Content="Automatisch" />
            </ComboBox>

            <TextBlock Text="Transkriptionsmodell" Grid.Row="1" Grid.Column="0" Style="{StaticResource RowLabel}" />
            <ComboBox x:Name="TranscriptionModelBox" Grid.Row="1" Grid.Column="1" Width="230" HorizontalAlignment="Left" IsEditable="True" Margin="0,0,0,8" SelectionChanged="ComboBox_Changed">
              <ComboBoxItem Content="gpt-4o-mini-transcribe" />
              <ComboBoxItem Content="gpt-4o-transcribe" />
              <ComboBoxItem Content="whisper-1" />
            </ComboBox>

            <TextBlock Text="Aufnahmemodus" Grid.Row="2" Grid.Column="0" Style="{StaticResource RowLabel}" />
            <ComboBox x:Name="HotkeyModeBox" Grid.Row="2" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,0,0,10" SelectionChanged="ComboBox_Changed">
              <ComboBoxItem Content="Toggle" />
              <ComboBoxItem Content="Halten" />
            </ComboBox>

            <CheckBox x:Name="AutoPasteBox" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                      Content="Nach Ergebnis automatisch mit Strg+V einf&#x00FC;gen"
                      Margin="0,0,0,6" Checked="Setting_Changed" Unchecked="Setting_Changed" />

<TextBlock Text="Mikrofon" Grid.Row="5" Grid.Column="0" Style="{StaticResource RowLabel}" />
            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
              <ComboBox x:Name="MicrophoneBox" DisplayMemberPath="Name" SelectedValuePath="Index" MinWidth="200" SelectionChanged="ComboBox_Changed" />
              <Button Content="&#x21BB;" Margin="8,0,0,0" Width="32" Padding="0" Click="CheckMicrophone_Click" ToolTip="Mikrofone neu laden" />
            </StackPanel>

            <TextBlock x:Name="MicrophoneStatusText" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Noch nicht gepr&#x00FC;ft." Foreground="{StaticResource TextMuted}" FontSize="11" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Hotkeys -->
      <Border Style="{StaticResource Panel}">
        <StackPanel>
          <TextBlock Text="Hotkeys" Style="{StaticResource SectionTitle}" />
          <TextBlock Text="Globale Tastenkombinationen. Klicke in ein Feld und dr&#x00FC;cke die gew&#x00FC;nschte Kombination." Style="{StaticResource Description}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="BlitzBrief" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
            <TextBox x:Name="TranscriptionHotkeyBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" IsReadOnly="True"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown" PreviewKeyUp="HotkeyBox_PreviewKeyUp" GotKeyboardFocus="HotkeyBox_GotKeyboardFocus" />
            <Button Grid.Row="0" Grid.Column="2" Content="Zur&#x00FC;cksetzen" Margin="0,0,0,8" Click="ResetHotkeys_Click" />
            <TextBlock Text="Text verbessern" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
            <TextBox x:Name="TextImproverHotkeyBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,8" IsReadOnly="True"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown" PreviewKeyUp="HotkeyBox_PreviewKeyUp" GotKeyboardFocus="HotkeyBox_GotKeyboardFocus" />
            <TextBlock Text="&#x00C4;rger beruhigen" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
            <TextBox x:Name="DampfHotkeyBox" Grid.Row="2" Grid.Column="1" Margin="0,0,8,8" IsReadOnly="True"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown" PreviewKeyUp="HotkeyBox_PreviewKeyUp" GotKeyboardFocus="HotkeyBox_GotKeyboardFocus" />
            <TextBlock Text="Emoji erg&#x00E4;nzen" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" />
            <TextBox x:Name="EmojiHotkeyBox" Grid.Row="3" Grid.Column="1" Margin="0,0,8,0" IsReadOnly="True"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown" PreviewKeyUp="HotkeyBox_PreviewKeyUp" GotKeyboardFocus="HotkeyBox_GotKeyboardFocus" />
          </Grid>
          <TextBlock x:Name="HotkeyHelpText" Text="Mind. zwei Modifier-Tasten (Strg, Alt, Umschalt, Win) oder Modifier + weitere Taste." Style="{StaticResource Description}" Margin="0,8,0,0" />
        </StackPanel>
      </Border>

      <!-- Schnellstart & Latenz -->
      <Border Style="{StaticResource Panel}">
        <StackPanel>
          <TextBlock Text="Schnellstart &amp; Latenz" Style="{StaticResource SectionTitle}" />
          <CheckBox x:Name="RealtimeBox" Content="Echtzeit-Transkription (streamt w&#x00E4;hrend des Sprechens, geringere Latenz)"
                    Margin="0,0,0,8" Checked="Setting_Changed" Unchecked="Setting_Changed" />
          <TextBlock Text="Sendet das Audio live an OpenAI, statt erst nach dem Stopp hochzuladen. F&#x00E4;llt bei Verbindungsproblemen automatisch auf den klassischen Upload zur&#x00FC;ck. Nur f&#x00FC;r gpt-4o(-mini)-transcribe."
                     Style="{StaticResource Description}" Margin="0,0,0,8" />
          <CheckBox x:Name="DoubleTapEnabledBox" Content="Diktat per Doppeltipp starten/stoppen"
                    Margin="0,0,0,8" Checked="Setting_Changed" Unchecked="Setting_Changed" />
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Doppeltipp-Taste" Grid.Column="0" VerticalAlignment="Center" />
            <ComboBox x:Name="DoubleTapModifierBox" Grid.Column="1" Width="120" HorizontalAlignment="Left" SelectionChanged="ComboBox_Changed">
              <ComboBoxItem Content="Strg" />
              <ComboBoxItem Content="Alt" />
              <ComboBoxItem Content="Umschalt" />
            </ComboBox>
          </Grid>
          <CheckBox x:Name="PreRollEnabledBox" Content="Mikrofon vorab aktiv halten (verz&#x00F6;gerungsfreier Start)"
                    Checked="Setting_Changed" Unchecked="Setting_Changed" />
          <TextBlock Text="Hinweis: Bei aktivem Pre-Roll ist das Mikrofon dauerhaft aktiv." Style="{StaticResource Description}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>

      <!-- Text verbessern -->
      <Border Style="{StaticResource Panel}">
        <StackPanel>
          <TextBlock Text="Text verbessern" Style="{StaticResource SectionTitle}" />
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Schreibstil" Grid.Column="0" VerticalAlignment="Center" />
            <ComboBox x:Name="ToneBox" Grid.Column="1" SelectionChanged="ToneBox_SelectionChanged">
              <ComboBoxItem Content="Formell" />
              <ComboBoxItem Content="Neutral" />
              <ComboBoxItem Content="Locker" />
              <ComboBoxItem Content="J&#x00F6;rn 1 &#x2013; Nur bereinigen" />
              <ComboBoxItem Content="J&#x00F6;rn 2 &#x2013; Bereinigen + Kommandos" />
            </ComboBox>
            <Border x:Name="CommandsInfoBadge"
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Padding="8,4"
                    Background="#EFF6FF"
                    BorderBrush="#BFDBFE"
                    BorderThickness="1"
                    CornerRadius="10"
                    VerticalAlignment="Center"
                    Cursor="Help"
                    Visibility="Collapsed">
              <TextBlock Text="&#x2139; Kommandos" Foreground="#2563EB" FontSize="11" FontWeight="SemiBold">
                <TextBlock.ToolTip>
                  <ToolTip ToolTipService.ShowDuration="30000">
                    <StackPanel Margin="2">
                      <TextBlock Text="Sprachkommandos f&#x00FC;r Interpunktion" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" />
                      <TextBlock Text="Spreche diese W&#x00F6;rter, um Satzzeichen einzuf&#x00FC;gen:" Foreground="#555" FontSize="12" Margin="0,0,0,6" />
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="&#x201E;Satzende&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="." Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="&#x201E;Komma&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="," Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="&#x201E;Semikolon&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text=";" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="&#x201E;Doppelpunkt&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text=":" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="&#x201E;Ausrufezeichen&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="!" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="&#x201E;Fragezeichen&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="?" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="&#x201E;Gedankenstrich&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="6" Grid.Column="2" Text="&#x2014;" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="&#x201E;Anf&#x00FC;hrungszeichen auf/zu&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="7" Grid.Column="2" Text="&quot; / &quot;" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="&#x201E;Klammer auf/zu&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="8" Grid.Column="2" Text="( / )" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="&#x201E;neuer Absatz&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="9" Grid.Column="2" Text="Absatzumbruch" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="&#x201E;neue Zeile&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="10" Grid.Column="2" Text="Zeilenumbruch" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="11" Grid.Column="0" Text="&#x201E;Leerzeile&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="11" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="11" Grid.Column="2" Text="leere Zeile" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="12" Grid.Column="0" Text="&#x201E;Text einr&#x00FC;cken&#x201C;" Margin="0,2,12,2" FontFamily="Consolas" />
                        <TextBlock Grid.Row="12" Grid.Column="1" Text="&#x2192;" Margin="0,2,8,2" Foreground="#888" />
                        <TextBlock Grid.Row="12" Grid.Column="2" Text="Einr&#x00FC;ckung" Margin="0,2" FontFamily="Consolas" FontWeight="SemiBold" />
                      </Grid>
                    </StackPanel>
                  </ToolTip>
                </TextBlock.ToolTip>
              </TextBlock>
            </Border>
          </Grid>
          <CheckBox x:Name="SkipRewriteBox" Content="Nur Transkription + Kommandoersetzung (kein GPT-Rewrite)"
                    Margin="0,0,0,10" Checked="Setting_Changed" Unchecked="Setting_Changed" />
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Kontext" Grid.Column="0" VerticalAlignment="Center" />
            <TextBox x:Name="ContextBox" Grid.Column="1" LostFocus="Setting_Changed" />
          </Grid>
          <TextBlock Text="Eigene Anweisung" FontWeight="SemiBold" Margin="0,0,0,4" />
          <TextBox x:Name="TextPromptBox" MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" LostFocus="Setting_Changed" />
        </StackPanel>
      </Border>

      <!-- Ärger beruhigen -->
      <Border Style="{StaticResource Panel}">
        <StackPanel>
          <TextBlock Text="&#x00C4;rger beruhigen" Style="{StaticResource SectionTitle}" />
          <TextBlock Text="Macht emotional gesprochene Gedanken zu einer klaren, respektvollen Nachricht." Style="{StaticResource Description}" />
          <TextBox x:Name="DampfPromptBox" MinHeight="100" AcceptsReturn="True" TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" LostFocus="Setting_Changed" />
        </StackPanel>
      </Border>

      <!-- Emoji ergänzen -->
      <Border Style="{StaticResource Panel}">
        <StackPanel>
          <TextBlock Text="Emoji erg&#x00E4;nzen" Style="{StaticResource SectionTitle}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Emoji-Dichte" Grid.Column="0" VerticalAlignment="Center" />
            <ComboBox x:Name="EmojiDensityBox" Grid.Column="1" Width="120" HorizontalAlignment="Left" SelectionChanged="ComboBox_Changed">
              <ComboBoxItem Content="Wenig" />
              <ComboBoxItem Content="Mittel" />
              <ComboBoxItem Content="Viel" />
            </ComboBox>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Eigennamen und Begriffe -->
      <Border Style="{StaticResource Panel}">
        <StackPanel>
          <TextBlock Text="Eigennamen und Begriffe" Style="{StaticResource SectionTitle}" />
          <TextBlock Text="Ein Begriff pro Zeile. Hilft bei Namen, Fachbegriffen, Produkten und Projekten." Style="{StaticResource Description}" />
          <TextBox x:Name="CustomTermsBox" MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" LostFocus="Setting_Changed" />
        </StackPanel>
      </Border>

      <!-- Entwickler -->
      <Border Style="{StaticResource Panel}">
        <StackPanel>
          <TextBlock Text="Entwickler" Style="{StaticResource SectionTitle}" />
          <CheckBox x:Name="DebugModeBox" Content="Debug-Modus: Stufe 1 und Stufe 2 nach jedem Workflow anzeigen"
                    Checked="Setting_Changed" Unchecked="Setting_Changed" />
        </StackPanel>
      </Border>

      <TextBlock x:Name="SaveStatusText" Foreground="#1D7A3A" FontSize="12" Margin="0,2,0,18" />
    </StackPanel>
  </ScrollViewer>
</Window>
